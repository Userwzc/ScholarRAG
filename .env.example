# =============================================================================
# ScholarRAG 环境配置文件
# 复制此文件为 .env 并根据你的环境修改配置
# cp .env.example .env
# =============================================================================

# =============================================================================
# LLM API 配置 (OpenAI 兼容)
# =============================================================================

# OpenAI 兼容 API 的基础地址
# 使用本地 vLLM: http://localhost:8000/v1
# 使用 OpenAI: https://api.openai.com/v1
# 使用 Moonshot: https://api.moonshot.cn/v1
OPENAI_API_BASE=http://localhost:8000/v1

# API 密钥
# 本地 vLLM 通常不需要密钥，可留空
# OpenAI: sk-...
# Moonshot: sk-...
OPENAI_API_KEY=

# LLM 模型名称
# 本地 vLLM: 使用你加载的模型名称
# OpenAI: gpt-4, gpt-3.5-turbo
# Moonshot: moonshot-v1-8k, Pro/moonshotai/Kimi-K2.5
LLM_MODEL=Pro/moonshotai/Kimi-K2.5

# =============================================================================
# 嵌入模型配置 (Qwen3-VL)
# =============================================================================

# 本地 Qwen3-VL 嵌入模型路径
# 相对路径（相对于项目根目录）或绝对路径
# 模型下载: https://huggingface.co/Qwen/Qwen3-VL-Embedding-2B
EMBEDDING_MODEL=models/Qwen3-VL-Embedding-2B

# =============================================================================
# 向量数据库配置 (Qdrant)
# =============================================================================

# Qdrant 服务地址
QDRANT_HOST=localhost

# Qdrant 服务端口
QDRANT_PORT=6333

# Qdrant 集合名称（用于存储论文 chunks）
QDRANT_COLLECTION_NAME=papers_rag

# =============================================================================
# PDF 解析配置 (MinerU)
# =============================================================================

# MinerU 模型来源
# - modelscope: 从 ModelScope 下载（推荐，国内快）
# - huggingface: 从 HuggingFace 下载
# - local: 使用本地已下载的模型
MINERU_MODEL_SOURCE=modelscope

# MinerU 后端引擎
# - pipeline: 完整流水线（默认，精度高）
# - hybrid-auto-engine: 混合引擎（速度快）
MINERU_BACKEND=pipeline

# =============================================================================
# RAG 检索配置
# =============================================================================

# 检索返回的 top-k chunks 数量
# 值越大，给 LLM 的上下文越多，但可能引入噪声
RAG_TOP_K=5

# 相似度阈值 (0.0 - 1.0)
# 低于此阈值的 chunks 会被过滤
# 0.0 表示不过滤
SCORE_THRESHOLD=0.3

# 是否启用混合检索（稠密向量 + BM25 稀疏向量）
# 需要安装: pip install fastembed
# true | false
ENABLE_HYBRID=false

# =============================================================================
# Agent 配置
# =============================================================================

# Agent 最大迭代次数
# 防止无限循环，达到此次数后强制停止
AGENT_MAX_ITERATIONS=10

# =============================================================================
# 存储路径配置
# =============================================================================

# PDF 文件存储目录（用于 PDF 阅读器功能）
PDF_STORAGE_DIR=./data/pdfs

# MinerU 解析输出目录
PARSED_OUTPUT_DIR=./data/parsed

# 上传文件临时存储目录
API_UPLOAD_DIR=./data/uploads

# SQLite 数据库路径（任务和版本管理）
# 默认使用内存或项目目录下的 SQLite 文件
# DATABASE_URL=sqlite+aiosqlite:///./data/scholarrag.db

# =============================================================================
# API 服务配置 (FastAPI)
# =============================================================================

# API 服务监听地址
API_HOST=0.0.0.0

# API 服务端口
API_PORT=8000

# =============================================================================
# 评估配置（可选）
# =============================================================================

# 评估数据集路径
# EVAL_DATASET=tests/evaluation/dataset.json

# 评估报告输出目录
# EVAL_OUTPUT_DIR=./reports

# =============================================================================
# 开发配置（可选）
# =============================================================================

# 日志级别: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# 是否启用调试模式
# DEBUG=false
