# OpenAI-compatible LLM API
OPENAI_API_BASE=http://localhost:8000/v1
OPENAI_API_KEY=your_api_key_here

# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Local Qwen3-VL embedding model path (relative to project root)
EMBEDDING_MODEL=models/Qwen3-VL-Embedding-2B

# Local Qwen3-VL reranker model path (empty to disable)
RERANKER_MODEL=

# LLM model name
LLM_MODEL=Pro/moonshotai/Kimi-K2.5

# MinerU model source: local | modelscope | huggingface
MINERU_MODEL_SOURCE=modelscope

# MinerU backend: pipeline | hybrid-auto-engine
MINERU_BACKEND=pipeline

# RAG settings
RAG_TOP_K=5
SCORE_THRESHOLD=0.3
AGENT_MAX_ITERATIONS=10

# API settings (for FastAPI)
API_HOST=0.0.0.0
API_PORT=8000
API_UPLOAD_DIR=./data/uploads
